# MongoDB
MONGODB_URI=mongodb://localhost:27017/barbeiro

# NextAuth
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
NEXTAUTH_URL=http://localhost:3000

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Stripe (crie produtos/recorrência no dashboard e cole os Price IDs)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_PRICE_BASIC=
STRIPE_PRICE_PREMIUM=

# Vercel Blob (opcional) — em produção, use para upload via CDN (melhor desempenho).
# Se não definir, as imagens são salvas em base64 no MongoDB (funciona normalmente).
# Crie em vercel.com → Storage → Blob e cole o token aqui.
BLOB_READ_WRITE_TOKEN=
